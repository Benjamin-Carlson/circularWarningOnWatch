{
  "name": "circular-warning-on-watch",
  "version": "1.0.0",
  "description": "Bug reproduction for circular dependency warnings with rolldown vs rollup",
  "type": "module",
  "scripts": {
    "build:rollup": "rollup -c rollup.config.js",
    "build:rolldown": "rolldown -c rolldown.config.js",
    "watch:rollup": "rollup -c rollup.config.js --watch",
    "watch:rolldown": "rolldown -c rolldown.config.js --watch"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^12.3.0",
    "rolldown": "^1.0.0-rc.11",
    "rollup": "^4.60.0",
    "tslib": "^2.8.1",
    "typescript": "^6.0.2"
  }
}
